# When running backend locally (not in Docker), DBs are reachable on localhost
# Start just the infra first:  docker compose up timescaledb mongodb redis
DATABASE_URL=postgresql://ims:ims_secret@localhost:5432/ims
MONGODB_URL=mongodb://localhost:27017/ims
REDIS_URL=redis://localhost:6379
WORKER_COUNT=10
RATE_LIMIT_PER_SEC=10000
QUEUE_MAX_SIZE=50000
DEBOUNCE_WINDOW_SECONDS=10
CORS_ORIGINS=http://localhost:3000
PORT=8000
